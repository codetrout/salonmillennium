---
import BaseLayout from '../layouts/BaseLayout.astro';

const team = [
  {
    name: 'Elena Butte',
    role: 'Owner, Master Stylist & Colorist',
    description: 'Elena founded Salon Millennium in 2000 and has spent over 25 years perfecting her craft. Clients across the Bay Area call her "the best colorist" — known for her meticulous technique, thorough consultations, and an uncanny ability to deliver exactly the color you envision. Her specialties include balayage, color correction, highlights, and precision haircuts.',
  },
  {
    name: 'Sahar',
    role: 'Stylist & Colorist',
    description: "Elena's daughter and creative partner, Sahar brings warmth, energy, and a modern eye to every appointment. She specializes in balayage, curling, and keratin treatments. Clients love her personalized approach and attention to individual needs — and her dynamic with Elena makes every visit feel like time with family.",
  },
  {
    name: 'Quy Tran',
    role: 'Stylist',
    description: 'Quy is known for efficiency, skill, and a friendly demeanor that keeps clients coming back. She often accommodates same-day appointments and delivers haircuts that clients rave about. Her regulars praise her precision and the consistently excellent results.',
  },
  {
    name: 'Cindy',
    role: 'Stylist',
    description: 'With years of experience and a reputation for thoroughness, Cindy brings dedication and quality to every haircut. Clients appreciate her attention to detail, her steady hand, and the confidence they feel walking out of her chair.',
  },
];
---

<BaseLayout
  title="About — Salon Millennium | Our Story & Team"
  description="Meet Elena Butte and the Salon Millennium team. Over 25 years of master hair color and styling on California Ave in Palo Alto."
  canonicalPath="/about/"
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <p class="section-label">About Us</p>
      <h1>Our Story</h1>
    </div>
  </section>

  <!-- Elena's Story -->
  <section class="section">
    <div class="container story-grid fade-in">
      <div class="story-text">
        <h2 class="section-title">Founded on a Passion for Color</h2>
        <p>
          Elena Butte opened Salon Millennium in 2000 with a clear mission: to create
          a salon where every client feels seen, heard, and beautifully transformed.
          What began as a one-woman vision has grown into a beloved Palo Alto institution
          on California Ave — a place where artistry meets warmth.
        </p>
        <p>
          Hair color is Elena's signature. She approaches every appointment as a
          consultation-first experience — listening carefully, understanding your
          lifestyle and vision, then delivering results that exceed expectations.
          Her clients don't just return; they refer their friends, their daughters,
          their mothers.
        </p>
        <p>
          Today, Elena's daughter Sahar works alongside her, bringing the next
          generation of talent and a family energy that clients describe as
          "like coming home." Together with stylists Quy and Cindy, the Salon
          Millennium team combines decades of experience with genuine care for
          every person in the chair.
        </p>
      </div>
      <div class="story-image">
        <img
          src="/images/color-service.webp"
          alt="Stylist applying balayage color technique — warm honey-blonde highlights on dark hair"
          loading="lazy"
          width="480"
          height="600"
        />
      </div>
    </div>
  </section>

  <!-- Values -->
  <section class="section section-alt">
    <div class="container">
      <p class="section-label fade-in">What We Believe</p>
      <h2 class="section-title fade-in">Our Values</h2>
      <div class="values-grid">
        <div class="value-item fade-in">
          <div class="value-number">01</div>
          <h3>Color Excellence</h3>
          <p>We are colorists first. Every technique — balayage, highlights, correction — is executed with meticulous care and decades of expertise.</p>
        </div>
        <div class="value-item fade-in">
          <div class="value-number">02</div>
          <h3>Consultation First</h3>
          <p>Every appointment begins with a thorough conversation. We listen to what you want, understand your hair, and create a plan before we pick up a brush.</p>
        </div>
        <div class="value-item fade-in">
          <div class="value-number">03</div>
          <h3>Family Atmosphere</h3>
          <p>Walking into our salon feels like coming home. The mother-daughter energy of Elena and Sahar creates a genuine, fun, welcoming environment.</p>
        </div>
        <div class="value-item fade-in">
          <div class="value-number">04</div>
          <h3>Quality Products</h3>
          <p>We exclusively use KEVIN.MURPHY — sustainable, cruelty-free, salon-quality products that we sell at fair, non-inflated prices.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Team -->
  <section class="section">
    <div class="container">
      <p class="section-label fade-in">The People</p>
      <h2 class="section-title fade-in">Meet Our Team</h2>
      <div class="team-grid">
        {team.map((member, i) => (
          <div class="team-card fade-in">
            <div class="team-number">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="team-name">{member.name}</h3>
            <p class="team-role">{member.role}</p>
            <p class="team-desc">{member.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section-alt">
    <div class="container cta-block fade-in">
      <h2>Experience the Difference</h2>
      <p>Book a consultation and discover why Bay Area clients have trusted Elena and her team for over 25 years.</p>
      <a href="#book" class="btn btn-primary">Book Your Appointment</a>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: clamp(6rem, 10vw, 10rem) 0 clamp(2rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3.5rem);
  }

  .story-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: start;
  }

  .story-text p {
    margin-bottom: 1.25rem;
  }

  .story-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* Values */
  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  .value-item {
    padding: 2.5rem 2rem;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
  }

  .value-number {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 300;
    color: var(--color-accent);
    opacity: 0.4;
    margin-bottom: 0.75rem;
    line-height: 1;
  }

  .value-item h3 {
    margin-bottom: 0.75rem;
  }

  .value-item p {
    font-size: 0.9375rem;
  }

  /* Team */
  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  .team-card {
    padding: 2.5rem 2rem;
    border-left: 2px solid var(--color-accent);
    background-color: var(--color-card);
  }

  .team-number {
    font-family: var(--font-heading);
    font-size: 1.75rem;
    font-weight: 300;
    color: var(--color-accent);
    opacity: 0.4;
    margin-bottom: 0.5rem;
    line-height: 1;
  }

  .team-name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    margin-bottom: 0.25rem;
  }

  .team-role {
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .team-desc {
    font-size: 0.9375rem;
  }

  /* CTA Block */
  .cta-block {
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }

  .cta-block h2 {
    margin-bottom: 1rem;
  }

  .cta-block p {
    margin-bottom: 2rem;
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .story-grid {
      grid-template-columns: 1fr;
    }

    .story-image {
      order: -1;
    }

    .values-grid {
      grid-template-columns: 1fr;
    }

    .team-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
