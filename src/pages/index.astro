---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Salon Millennium — Hair Color & Styling in Palo Alto"
  description="Salon Millennium: hair color, balayage & cuts by Elena Butte on California Ave, Palo Alto. Open since 2000. Book your appointment today."
  canonicalPath="/"
>

  <!-- Hero -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="container hero-content">
      <p class="hero-label">California Ave, Palo Alto</p>
      <h1>Salon<br />Millennium</h1>
      <p class="hero-sub">Stay connected with the clients who love you</p>
      <a href="#book" class="btn btn-primary">Book Your Color Appointment</a>
    </div>
  </section>

  <!-- About Elena -->
  <section class="section">
    <div class="container about-intro fade-in">
      <p class="section-label">Our Story</p>
      <div class="about-intro-grid">
        <div class="about-intro-text">
          <h2 class="section-title">Color is Our Craft</h2>
          <p>
            Elena Butte founded Salon Millennium in 2000 with a simple idea: thoughtful
            hair color in a warm, personal atmosphere. Twenty-five years later, her
            clients still return — often bringing their daughters, mothers, and friends
            with them.
          </p>
          <p>
            Today, Elena and her daughter Sahar work side-by-side on California Ave,
            building the family atmosphere and careful color work the salon has come
            to be known for.
          </p>
          <a href="/about/" class="btn btn-outline about-cta">Meet the Team</a>
        </div>
        <div class="about-intro-image">
          <img
            src="/images/salon-atmosphere.webp"
            alt="Interior of Salon Millennium on California Ave, Palo Alto — warm lighting and elegant styling stations"
            loading="lazy"
            width="720"
            height="405"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Services Overview -->
  <section class="section section-alt">
    <div class="container">
      <p class="section-label fade-in">What We Do</p>
      <h2 class="section-title fade-in">Services</h2>
      <div class="services-grid">
        <div class="service-card fade-in">
          <div class="service-number">01</div>
          <h3>Hair Color</h3>
          <p>Balayage, highlights, color correction, root touch-ups — color is what we do most. Elena's careful technique is built around natural, dimensional results.</p>
          <a href="/services/" class="service-link">Learn more &rarr;</a>
        </div>
        <div class="service-card fade-in">
          <div class="service-number">02</div>
          <h3>Haircuts</h3>
          <p>Precision cuts for men and women. Our stylists combine technical skill with an eye for shape, movement, and individual style.</p>
          <a href="/services/" class="service-link">Learn more &rarr;</a>
        </div>
        <div class="service-card fade-in">
          <div class="service-number">03</div>
          <h3>Treatments & Styling</h3>
          <p>Keratin treatments, blow drys, and styling for every occasion. Smooth, healthy, camera-ready hair using KEVIN.MURPHY products.</p>
          <a href="/services/" class="service-link">Learn more &rarr;</a>
        </div>
      </div>
      <div class="services-cta fade-in">
        <a href="/services/" class="btn btn-outline">View All Services</a>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="section">
    <div class="container">
      <p class="section-label fade-in">Kind Words</p>
      <h2 class="section-title fade-in">What Our Clients Say</h2>
      <div class="testimonials-grid">
        <blockquote class="testimonial fade-in">
          <p>&ldquo;Elena is the best colorist in the Bay Area. She listens to exactly what you want and gives great advice. The salon is beautiful and products are fairly priced.&rdquo;</p>
          <cite>
            <strong>Simone D.</strong>
            <span>Belmont &mdash; via Yelp</span>
          </cite>
        </blockquote>
        <blockquote class="testimonial fade-in">
          <p>&ldquo;Elena is pure magic with highlights. She's fast too — highlights and a cut in about 90 minutes. I've been going to her for years and have never been disappointed.&rdquo;</p>
          <cite>
            <strong>Lisa N.</strong>
            <span>via Google</span>
          </cite>
        </blockquote>
        <blockquote class="testimonial fade-in">
          <p>&ldquo;I got balayage from Elena and it was exactly what I wanted. Sahar curled my hair beautifully after. The mother-daughter duo is just wonderful — warm, fun, and so skilled.&rdquo;</p>
          <cite>
            <strong>Nidhi S.</strong>
            <span>Sunnyvale &mdash; via Yelp</span>
          </cite>
        </blockquote>
      </div>
      <div class="testimonials-cta fade-in">
        <a href="/reviews/" class="btn btn-outline">Read More Reviews</a>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="section section-alt">
    <div class="container">
      <div class="products-grid fade-in">
        <div class="products-image">
          <img
            src="/images/products-display.webp"
            alt="Curated display of KEVIN.MURPHY hair care products"
            loading="lazy"
            width="600"
            height="400"
          />
        </div>
        <div class="products-text">
          <p class="section-label">Our Products</p>
          <h2 class="section-title">KEVIN.MURPHY</h2>
          <p class="products-tagline">Skin Care for Your Hair</p>
          <p>
            We exclusively feature KEVIN.MURPHY — sustainable, cruelty-free,
            salon-quality products at fair, non-inflated prices. From washes and
            treatments to styling and colour care, every product is chosen to
            deliver results you can feel.
          </p>
          <a href="https://kevinmurphy.com.au/us/en/pro/" target="_blank" rel="noopener noreferrer" class="btn btn-outline products-btn">Explore Products</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Bar -->
  <section class="section contact-bar">
    <div class="container contact-bar-inner fade-in">
      <div class="contact-bar-text">
        <h2>Ready to Book?</h2>
        <p>Visit us at 409 California Ave, Palo Alto &mdash; or call <a href="tel:6506542088">(650) 654-2088</a></p>
      </div>
      <a href="#book" class="btn btn-primary">Book Your Appointment</a>
    </div>
  </section>

</BaseLayout>

<style>
  /* Hero */
  .hero {
    position: relative;
    min-height: 85vh;
    display: flex;
    align-items: center;
    background-image: url('/images/hero-salon.webp');
    background-size: cover;
    background-position: center;
    background-color: var(--color-text);
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      rgba(44, 40, 37, 0.75) 0%,
      rgba(44, 40, 37, 0.4) 60%,
      rgba(44, 40, 37, 0.2) 100%
    );
  }

  .hero-content {
    position: relative;
    color: var(--color-bg);
    padding: 6rem 0;
  }

  .hero-label {
    font-family: var(--font-body);
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    margin-bottom: 1.5rem;
    opacity: 0.8;
  }

  .hero h1 {
    margin-bottom: 1.5rem;
    max-width: 600px;
  }

  .hero-sub {
    font-family: var(--font-heading);
    font-size: clamp(1.125rem, 2vw, 1.5rem);
    font-weight: 300;
    font-style: italic;
    margin-bottom: 2.5rem;
    opacity: 0.9;
  }

  /* About Intro */
  .about-intro-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }

  .about-intro-text p {
    margin-bottom: 1.25rem;
  }

  .about-cta {
    margin-top: 0.5rem;
  }

  .about-intro-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* Services Grid */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  .service-card {
    padding: 2.5rem 2rem;
    background-color: var(--color-bg);
    border: 1px solid var(--color-border);
    transition: box-shadow 0.3s ease;
  }

  .service-card:hover {
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.06);
  }

  .service-number {
    font-family: var(--font-heading);
    font-size: 2.5rem;
    font-weight: 300;
    color: var(--color-accent);
    opacity: 0.4;
    margin-bottom: 1rem;
    line-height: 1;
  }

  .service-card h3 {
    margin-bottom: 1rem;
  }

  .service-card p {
    font-size: 0.9375rem;
    margin-bottom: 1.25rem;
  }

  .service-link {
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .services-cta {
    text-align: center;
    margin-top: 3rem;
  }

  /* Testimonials */
  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  .testimonial {
    padding: 2.5rem 2rem;
    border-left: 2px solid var(--color-accent);
    background-color: var(--color-card);
  }

  .testimonial p {
    font-family: var(--font-heading);
    font-size: 1.125rem;
    font-weight: 400;
    font-style: italic;
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .testimonial cite {
    font-style: normal;
    display: block;
  }

  .testimonial cite strong {
    display: block;
    font-family: var(--font-body);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .testimonial cite span {
    font-size: 0.75rem;
    opacity: 0.6;
  }

  .testimonials-cta {
    text-align: center;
    margin-top: 3rem;
  }

  /* Products */
  .products-grid {
    display: grid;
    grid-template-columns: 2fr 3fr;
    gap: clamp(2rem, 4vw, 4rem);
    align-items: center;
  }

  .products-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .products-tagline {
    font-family: var(--font-heading);
    font-size: 1.25rem;
    font-weight: 300;
    font-style: italic;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .products-text p {
    margin-bottom: 1rem;
  }

  .products-btn {
    margin-top: 0.5rem;
  }

  /* Contact Bar */
  .contact-bar {
    background-color: var(--color-text);
    color: var(--color-bg);
  }

  .contact-bar-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 2rem;
  }

  .contact-bar h2 {
    color: var(--color-bg);
    margin-bottom: 0.5rem;
  }

  .contact-bar p {
    opacity: 0.7;
  }

  .contact-bar a:not(.btn) {
    color: var(--color-accent);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .hero {
      min-height: 70vh;
    }

    .about-intro-grid {
      grid-template-columns: 1fr;
    }

    .about-intro-image {
      order: -1;
    }

    .services-grid {
      grid-template-columns: 1fr;
    }

    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .products-grid {
      grid-template-columns: 1fr;
    }

    .products-image {
      order: -1;
    }

    .contact-bar-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
