---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { services } from '../../data/services';

export function getStaticPaths() {
  return services.map((service) => ({
    params: { slug: service.slug },
    props: { service },
  }));
}

const { service } = Astro.props;

const related = services
  .filter((s) => s.category === service.category && s.slug !== service.slug)
  .slice(0, 3);
---

<BaseLayout
  title={service.seoTitle}
  description={service.seoDescription}
  canonicalPath={`/services/${service.slug}/`}
>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <p class="section-label">
        <a href="/services/" class="breadcrumb">Services</a> &nbsp;/&nbsp;
        {service.category === 'color' ? 'Hair Color' : 'Cuts, Treatments & More'}
      </p>
      <h1>{service.name}</h1>
    </div>
  </section>

  <!-- Intro + Image -->
  <section class="section">
    <div class="container intro-grid fade-in">
      <div class="intro-text">
        <p class="lede">{service.intro}</p>
        <a href="#book" class="btn btn-primary">Book This Service</a>
        <a href="tel:6506542088" class="phone-cta">or call (650) 654-2088</a>
      </div>
      <div class="intro-image">
        <img
          src={`/images/services/${service.slug}.png`}
          alt={service.imageAlt}
          loading="eager"
          width="800"
          height="1000"
        />
      </div>
    </div>
  </section>

  <!-- Body Copy -->
  <section class="section section-alt">
    <div class="container body-grid fade-in">
      <div class="body-text">
        {service.body.map((para) => <p>{para}</p>)}
      </div>
      <aside class="what-to-expect">
        <p class="section-label">What to Expect</p>
        <ul role="list">
          {service.whatToExpect.map((item) => <li>{item}</li>)}
        </ul>
      </aside>
    </div>
  </section>

  <!-- Related Services -->
  {related.length > 0 && (
    <section class="section">
      <div class="container">
        <p class="section-label fade-in">You Might Also Like</p>
        <h2 class="section-title fade-in">
          {service.category === 'color' ? 'More Color Services' : 'More Services'}
        </h2>

        <div class="related-grid">
          {related.map((r) => (
            <a href={`/services/${r.slug}/`} class="related-card fade-in">
              <img
                src={`/images/services/${r.slug}.png`}
                alt={r.imageAlt}
                loading="lazy"
                width="400"
                height="500"
              />
              <h3>{r.name}</h3>
              <p>{r.shortDescription}</p>
              <span class="related-link">Read more &rarr;</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Final CTA -->
  <section class="section section-alt">
    <div class="container cta-block fade-in">
      <h2>Ready to Book?</h2>
      <p>
        Salon Millennium is located inside Casual Chic Salon at 409 California Ave,
        in the heart of downtown Palo Alto. Reserve your appointment online or give us a call —
        we're always happy to talk through your options first.
      </p>
      <div class="cta-buttons">
        <a href="#book" class="btn btn-primary">Book Online</a>
        <a href="tel:6506542088" class="btn btn-outline">Call (650) 654-2088</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding: clamp(6rem, 10vw, 10rem) 0 clamp(2rem, 4vw, 4rem);
    border-bottom: 1px solid var(--color-border);
  }

  .page-header h1 {
    font-size: clamp(2rem, 4vw, 3.5rem);
  }

  .breadcrumb {
    color: var(--color-accent);
    font-size: inherit;
    letter-spacing: inherit;
    text-transform: inherit;
  }

  /* Intro */
  .intro-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  .lede {
    font-family: var(--font-heading);
    font-size: clamp(1.25rem, 2.2vw, 1.625rem);
    font-weight: 400;
    line-height: 1.5;
    margin-bottom: 2rem;
    color: var(--color-text);
  }

  .phone-cta {
    display: inline-block;
    margin-left: 1.25rem;
    font-size: 0.9375rem;
    color: var(--color-text);
    opacity: 0.7;
  }

  .phone-cta:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .intro-image img {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /* Body */
  .body-grid {
    display: grid;
    grid-template-columns: 3fr 2fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }

  .body-text p {
    margin-bottom: 1.25rem;
  }

  .body-text p:last-child {
    margin-bottom: 0;
  }

  .what-to-expect {
    padding: 2rem;
    background-color: var(--color-bg);
    border-left: 2px solid var(--color-accent);
  }

  .what-to-expect ul {
    list-style: none;
  }

  .what-to-expect li {
    position: relative;
    padding-left: 1.25rem;
    margin-bottom: 0.875rem;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .what-to-expect li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.65em;
    width: 0.5rem;
    height: 1px;
    background-color: var(--color-accent);
  }

  .what-to-expect li:last-child {
    margin-bottom: 0;
  }

  /* Related */
  .related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 2rem;
  }

  .related-card {
    color: var(--color-text);
    display: flex;
    flex-direction: column;
  }

  .related-card img {
    width: 100%;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    margin-bottom: 1.25rem;
    transition: opacity 0.3s ease;
  }

  .related-card:hover img {
    opacity: 0.92;
  }

  .related-card h3 {
    margin-bottom: 0.5rem;
  }

  .related-card p {
    font-size: 0.9375rem;
    margin-bottom: 1rem;
    flex: 1;
  }

  .related-link {
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
  }

  /* CTA */
  .cta-block {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .cta-block h2 {
    margin-bottom: 1rem;
  }

  .cta-block p {
    margin-bottom: 2rem;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 768px) {
    .intro-grid,
    .body-grid {
      grid-template-columns: 1fr;
    }

    .intro-image {
      order: -1;
    }

    .related-grid {
      grid-template-columns: 1fr;
    }

    .phone-cta {
      display: block;
      margin-left: 0;
      margin-top: 1rem;
    }
  }
</style>
